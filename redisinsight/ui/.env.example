# RedisInsight UI — environment variable template
#
# Copy to `.env` in this directory and adjust:  cp .env.example .env
# Full reference (all variables, defaults, descriptions): docs/env-variables.md
#
# NOTE: only RI_* variables reach the browser (Vite `envPrefix: 'RI_'`), and they are
# inlined AT BUILD TIME — changing them requires a rebuild, not just a restart.
# Values shown are the built-in defaults.

# ---- API connection ----
# RI_API_PREFIX=api
# RI_APP_PORT=5540
# RI_BASE_API_URL=http://localhost
# RI_CSRF_ENDPOINT=
# RI_SOCKET_TRANSPORTS=
# RI_SOCKET_CREDENTIALS=false

# ---- Hosted (cloud-served) builds ----
# RI_HOSTED_API_BASE_URL=
# RI_HOSTED_BASE=
# RI_HOSTED_SOCKET_PROXY_PATH=

# ---- Appearance & behaviour ----
# RI_DEFAULT_THEME=SYSTEM             # SYSTEM | DARK | LIGHT
# RI_APP_TYPE=
# RI_401_REDIRECT_URL=
# RI_SM_REDIRECT_URL=
# RI_DB_UPGRADE_REDIRECT_URL=
# RI_SESSION_TTL_SECONDS=1800
# RI_SHOULD_GET_RECOMMENDATIONS=false

# ---- Data / limits ----
# RI_SCAN_COUNT_DEFAULT=500
# RI_SCAN_TREE_COUNT_DEFAULT=10000
# RI_CONNECTIONS_TIMEOUT_DEFAULT=30000

# ---- Error reporting (secrets) ----
# RI_SENTRY_ENABLED=false
# RI_SENTRY_DSN=<sentry-dsn>
# RI_SENTRY_ENVIRONMENT=development

# ---- Build-time source-map upload (secrets) ----
# RI_SENTRY_AUTH_TOKEN=<token>
# RI_SENTRY_ORG=
# RI_SENTRY_PROJECT=
