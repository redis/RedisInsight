{
  "author": {
    "name": "Redis Ltd.",
    "email": "support@redis.com",
    "url": "https://redis.com/redis-enterprise/redis-insight"
  },
  "bugs": {
    "url": "https://github.com/redis/RedisInsight/issues"
  },
  "description": "Redis Insight geospatial Workbench visualizations",
  "source": "./src/main.tsx",
  "styles": "./dist/styles.css",
  "main": "./dist/index.js",
  "name": "geodata",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite -c ../vite.config.mjs",
    "test": "node ../../../../../node_modules/.bin/jest -c jest.config.cjs",
    "typecheck": "node ../../../../../node_modules/.bin/tsc --project tsconfig.json --noEmit"
  },
  "visualizations": [
    {
      "id": "ri-geodata-map",
      "name": "Geospatial map",
      "activationMethod": "renderGeoMapMarkers",
      "matchCommands": [
        "GEOSEARCH",
        "GEORADIUS",
        "GEORADIUS_RO",
        "GEORADIUSBYMEMBER",
        "GEORADIUSBYMEMBER_RO"
      ],
      "matchQuery": {
        "anyRegex": [
          "(?:\\bGEOSEARCH\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:FROMLONLAT\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|FROMMEMBER\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))\\s+(?:BYRADIUS\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|BYBOX\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))|\\bGEORADIUS(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|\\bGEORADIUSBYMEMBER(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))(?=[\\s\\S]{0,4096}\\bWITHCOORD\\b)"
        ]
      },
      "iconDark": "./dist/geodata_icon_dark.svg",
      "iconLight": "./dist/geodata_icon_light.svg",
      "description": "Show geospatial command results as plotted locations",
      "default": true
    },
    {
      "id": "ri-geodata-heatmap",
      "name": "Geospatial heatmap",
      "activationMethod": "renderGeoMapHeatmap",
      "matchCommands": [
        "GEOSEARCH",
        "GEORADIUS",
        "GEORADIUS_RO",
        "GEORADIUSBYMEMBER",
        "GEORADIUSBYMEMBER_RO"
      ],
      "matchQuery": {
        "anyRegex": [
          "(?:\\bGEOSEARCH\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:FROMLONLAT\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|FROMMEMBER\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))\\s+(?:BYRADIUS\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|BYBOX\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))|\\bGEORADIUS(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|\\bGEORADIUSBYMEMBER(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))(?=[\\s\\S]{0,4096}\\bWITHCOORD\\b)"
        ]
      },
      "iconDark": "./dist/geodata_heatmap_icon_dark.svg",
      "iconLight": "./dist/geodata_heatmap_icon_light.svg",
      "description": "Show geospatial command result density",
      "default": false
    },
    {
      "id": "ri-geodata-inspector",
      "name": "Geospatial details",
      "activationMethod": "renderGeoInspector",
      "matchCommands": [
        "GEOADD",
        "GEODIST",
        "GEOHASH",
        "GEOPOS",
        "GEOSEARCHSTORE"
      ],
      "iconDark": "./dist/geodata_inspector_icon_dark.svg",
      "iconLight": "./dist/geodata_inspector_icon_light.svg",
      "description": "Inspect Redis geospatial command inputs and results",
      "default": true
    },
    {
      "id": "ri-geodata-search-inspector",
      "name": "Geospatial details",
      "activationMethod": "renderGeoInspector",
      "matchCommands": [
        "GEOSEARCH",
        "GEORADIUS",
        "GEORADIUS_RO",
        "GEORADIUSBYMEMBER",
        "GEORADIUSBYMEMBER_RO"
      ],
      "matchQuery": {
        "noneRegex": [
          "(?:\\bGEOSEARCH\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:FROMLONLAT\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|FROMMEMBER\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))\\s+(?:BYRADIUS\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|BYBOX\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))|\\bGEORADIUS(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|\\bGEORADIUSBYMEMBER(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))(?=[\\s\\S]{0,4096}\\bWITHCOORD\\b)"
        ]
      },
      "iconDark": "./dist/geodata_inspector_icon_dark.svg",
      "iconLight": "./dist/geodata_inspector_icon_light.svg",
      "description": "Inspect Redis geospatial command inputs and results",
      "default": true
    },
    {
      "id": "ri-geodata-coordinate-inspector",
      "name": "Geospatial details",
      "activationMethod": "renderGeoInspector",
      "matchCommands": [
        "GEOSEARCH",
        "GEORADIUS",
        "GEORADIUS_RO",
        "GEORADIUSBYMEMBER",
        "GEORADIUSBYMEMBER_RO"
      ],
      "matchQuery": {
        "anyRegex": [
          "(?:\\bGEOSEARCH\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:FROMLONLAT\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|FROMMEMBER\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))\\s+(?:BYRADIUS\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|BYBOX\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))|\\bGEORADIUS(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})|\\bGEORADIUSBYMEMBER(?:_RO)?\\b\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512})\\s+(?:\"[^\"\\r\\n]{0,512}\"|'[^'\\r\\n]{0,512}'|[^\\s\"']{1,512}))(?=[\\s\\S]{0,4096}\\bWITHCOORD\\b)"
        ]
      },
      "iconDark": "./dist/geodata_inspector_icon_dark.svg",
      "iconLight": "./dist/geodata_inspector_icon_light.svg",
      "description": "Inspect Redis geospatial command inputs and results",
      "default": false
    },
    {
      "id": "ri-geodata-rqe-map",
      "name": "Search geospatial map",
      "activationMethod": "renderRedisSearchGeoMap",
      "matchCommands": [
        "FT.SEARCH",
        "FT.AGGREGATE",
        "FT.HYBRID"
      ],
      "matchQuery": {
        "anyRegex": [
          "@[A-Za-z0-9_.$:-]{1,128}:\\[\\s*[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\s*\\]",
          "\\bGEOFILTER\\s+[A-Za-z0-9_.$:-]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\b"
        ]
      },
      "iconDark": "./dist/geodata_icon_dark.svg",
      "iconLight": "./dist/geodata_icon_light.svg",
      "description": "Show Redis Search GEO results as plotted locations",
      "default": false
    },
    {
      "id": "ri-geodata-rqe-heatmap",
      "name": "Search geospatial heatmap",
      "activationMethod": "renderRedisSearchGeoHeatmap",
      "matchCommands": [
        "FT.SEARCH",
        "FT.AGGREGATE",
        "FT.HYBRID"
      ],
      "matchQuery": {
        "anyRegex": [
          "@[A-Za-z0-9_.$:-]{1,128}:\\[\\s*[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\s*\\]",
          "\\bGEOFILTER\\s+[A-Za-z0-9_.$:-]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\b"
        ]
      },
      "iconDark": "./dist/geodata_heatmap_icon_dark.svg",
      "iconLight": "./dist/geodata_heatmap_icon_light.svg",
      "description": "Show Redis Search GEO result density",
      "default": false
    },
    {
      "id": "ri-geodata-rqe-inspector",
      "name": "Search geospatial details",
      "activationMethod": "renderRedisSearchGeoInspector",
      "matchCommands": [
        "FT.SEARCH",
        "FT.AGGREGATE",
        "FT.HYBRID"
      ],
      "matchQuery": {
        "anyRegex": [
          "@[A-Za-z0-9_.$:-]{1,128}:\\[\\s*[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\s*\\]",
          "\\bGEOFILTER\\s+[A-Za-z0-9_.$:-]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+[-+$A-Za-z0-9_.]{1,128}\\s+(?:m|km|mi|ft)\\b",
          "@[A-Za-z0-9_.$:-]{1,128}:\\[\\s*(?:WITHIN|CONTAINS|INTERSECTS|DISJOINT)\\s+[^\\]]{1,2048}\\]"
        ]
      },
      "iconDark": "./dist/geodata_inspector_icon_dark.svg",
      "iconLight": "./dist/geodata_inspector_icon_light.svg",
      "description": "Inspect Redis Search geospatial command inputs and results",
      "default": false
    },
    {
      "id": "ri-geodata-rqe-shape",
      "name": "Search geoshape map",
      "activationMethod": "renderRedisSearchGeoShape",
      "matchCommands": [
        "FT.SEARCH",
        "FT.AGGREGATE",
        "FT.HYBRID"
      ],
      "matchQuery": {
        "anyRegex": [
          "@[A-Za-z0-9_.$:-]{1,128}:\\[\\s*(?:WITHIN|CONTAINS|INTERSECTS|DISJOINT)\\s+[^\\]]{1,2048}\\]"
        ]
      },
      "iconDark": "./dist/geodata_inspector_icon_dark.svg",
      "iconLight": "./dist/geodata_inspector_icon_light.svg",
      "description": "Show Redis Search GEOSHAPE WKT results",
      "default": false
    }
  ],
  "devDependencies": {
    "@types/leaflet": "^1.9.3",
    "@types/leaflet.markercluster": "^1.5.6",
    "vite": "file:../node_modules/vite"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "resolutions": {
    "**/semver": "^7.5.2"
  }
}
