# RedisInsight Desktop (Electron) — environment variable template
#
# Copy to `.env` in this directory and adjust:  cp .env.example .env
# Full reference (all variables, defaults, descriptions): docs/env-variables.md

# ---- Auto-update ----
# RI_UPGRADES_LINK=            # URL the auto-updater checks for upgrades
# RI_MANUAL_UPGRADES_LINK=     # URL for manual upgrade downloads
# RI_DISABLE_AUTO_UPGRADE=false
# RI_AUTO_UPDATE_INTERVAL=

# ---- Window / startup ----
# START_MINIMIZED=false
# UPGRADE_EXTENSIONS=false     # install/upgrade dev browser extensions (development aid)

# ---- Cloud OAuth callback ----
# USE_TCP_CLOUD_AUTH=false
# TCP_LOCAL_AUTH_PORT=
# TCP_LOCAL_CLOUD_AUTH_PORT=

# ---- Error reporting (secrets) ----
# RI_SENTRY_ENABLED=false
# RI_SENTRY_DSN=<sentry-dsn>
# RI_SENTRY_ENVIRONMENT=development
