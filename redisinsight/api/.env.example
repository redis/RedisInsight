# RedisInsight API — environment variable template
#
# Copy to `.env` in this directory and adjust:  cp .env.example .env
# Full reference (all variables, defaults, descriptions): docs/env-variables.md
#
# Values shown are the built-in defaults. Uncomment and change only what you need.
# NEVER commit real secrets — the placeholders below (<...>) must be replaced locally.

# ---- Server & network ----
# RI_APP_HOST=0.0.0.0
# RI_APP_PORT=5540
# RI_BASE=/
# RI_PROXY_PATH=
# RI_EXTERNAL_URL=            # external URL for OAuth callbacks behind a proxy/custom port
# RI_REQUEST_TIMEOUT=25000
# RI_MAX_PAYLOAD_SIZE=512MB
# RI_CORS_ORIGIN=*
# RI_CORS_CREDENTIALS=false
# RI_DATABASE_MANAGEMENT=true
# RI_SERVE_STATICS=true
# RI_BUILD_TYPE=DOCKER_ON_PREMISE   # ELECTRON | DOCKER_ON_PREMISE | REDIS_STACK
# RI_APP_TYPE=

# ---- Storage & paths ----
# RI_DATA_DIR=
# RI_PRE_SETUP_DATABASES_PATH=

# ---- Security & encryption (secrets) ----
# RI_ENCRYPTION_KEY=<aes-key>
# RI_ENCRYPTION_KEYTAR=true
# RI_SECRET_STORAGE_PASSWORD=<password>
# RI_SERVER_TLS_CERT=<pem-cert>       # set cert+key to serve the API over HTTPS
# RI_SERVER_TLS_KEY=<pem-key>

# ---- Logging ----
# RI_LOG_LEVEL=info                   # info | debug | warn | error
# RI_STDOUT_LOGGER=false
# RI_FILES_LOGGER=true
# RI_LOGGER_OMIT_DATA=true

# ---- Analytics & telemetry ----
# RI_SEGMENT_WRITE_KEY=<segment-write-key>
# RI_ANALYTICS_START_EVENTS=false

# ---- Redis Cloud & OAuth (secrets) ----
# RI_CLOUD_API_URL=
# RI_CLOUD_API_TOKEN=<token>
# RI_CLOUD_CAPI_URL=
# RI_CLOUD_IDP_AUTHORIZE_URL=
# RI_CLOUD_IDP_TOKEN_URL=
# RI_CLOUD_IDP_ISSUER=
# RI_CLOUD_IDP_CLIENT_ID=<client-id>
# RI_CLOUD_IDP_REDIRECT_URI=
# Per-provider overrides: RI_CLOUD_IDP_GOOGLE_*, RI_CLOUD_IDP_GH_*, RI_CLOUD_IDP_SSO_*

# ---- AI (Copilot / ConvAI) (secrets) ----
# RI_AI_CONVAI_API_URL=
# RI_AI_CONVAI_TOKEN=<token>

# ---- Pre-setup databases (auto-add on startup) ----
# Define RI_REDIS_HOST (optionally _1, _2, ... for multiple databases).
# RI_REDIS_HOST=
# RI_REDIS_PORT=6379
# RI_REDIS_ALIAS=
# RI_REDIS_USERNAME=<username>
# RI_REDIS_PASSWORD=<password>
# RI_REDIS_TLS=false
