{
  // The root tsconfig serves three jobs:
  //   1. `paths` map for `tsconfig-paths-webpack-plugin` in
  //      `configs/webpack.config.base.ts` — resolves `apiSrc/*`, `uiSrc/*`,
  //      `desktopSrc/*`, and `apiClient(/**)` when bundling the desktop
  //      electron-main process.
  //   2. ESLint parser project for files not covered by a more specific
  //      override (`tests/playwright/**`, `stories/**`, etc.).
  //   3. IDE root for TypeScript "workspace" awareness.
  //
  // It is NOT the type-check target for the UI — that lives in
  // `redisinsight/ui/tsconfig.json` and is run via `yarn type-check:ui`.
  // The API has its own self-contained `redisinsight/api/tsconfig.json`.
  // Storybook extends `redisinsight/ui/tsconfig.json`.
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["dom", "esnext", "WebWorker"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "jsx": "react",
    "strict": true,
    "pretty": true,
    "sourceMap": true,
    "baseUrl": "./",
    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    /* Module Resolution Options */
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "paths": {
      "uiSrc/*": ["redisinsight/ui/src/*"],
      "apiSrc/*": ["redisinsight/api/src/*"],
      "apiClient": ["redisinsight/api-client"],
      "apiClient/*": ["redisinsight/api-client/*"],
      "src/*": ["redisinsight/api/src/*"],
      "desktopSrc/*": ["redisinsight/desktop/src/*"],
      "tests/*": ["redisinsight/ui/__tests__/*"]
    }
  },
  "include": [
    "redisinsight/ui/src/**/*",
    "redisinsight/ui/index.tsx",
    "redisinsight/ui/indexElectron.tsx",
    "redisinsight/api-client/**/*",
    "redisinsight/desktop/**/*",
    "redisinsight/ui/vite-env.d.ts",
    "jest.config.cjs",
    "tests/playwright/**/*",
    "stories/**/*"
  ],
  "exclude": [
    "redisinsight/desktop/dll/*",
    "./redisinsight/api",
    "**/main.prod.js",
    "**/renderer.prod.js",
    "./release",
    "./node_modules",
    "**/node_modules",
    "./dist",
    "**/dist"
  ]
}
